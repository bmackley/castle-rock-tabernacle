# ── Supabase ──────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Only this email may access /admin (defense-in-depth on top of Supabase Auth).
ADMIN_EMAIL=

# ── Resend (transactional email) ──────────────────────────────────────
# Until you verify a domain in Resend, use onboarding@resend.dev as the From.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where new-reservation + contact-form notifications are sent.
ADMIN_NOTIFY_EMAIL=

# ── Cron (Vercel) ─────────────────────────────────────────────────────
# A long random string. Vercel sends it as the Authorization bearer token.
CRON_SECRET=
